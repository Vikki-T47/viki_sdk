{
  "enterprise_src_limits": {
    "provider": "local",
    "local_config": {
      "base_url": "http://localhost:11434/v1",
      "model": "llama3"
    },
    "max_auto_transaction_usd": 1000,
    "allowed_auto_execution_hours": {"start": 9, "end": 21},
    "critical_actions_require_human": ["delete_database", "mass_mailing"],
    "forbidden_paths": ["C:/Windows", "/etc", ".env"],
    "allowed_domains": ["quotes.toscrape.com", "techcrunch.com", "theverge.com", "github.com"],
    "data_freshness_days": 7
  },
  "context_policies": {
    "production": {"max_auto_transaction_usd": 1000},
    "simulation": {"max_auto_transaction_usd": 5000}
  },
  "dynamic_rules": {
    "reduce_after_error": true,
    "error_reduction_percent": 15
  }
}